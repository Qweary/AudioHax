    "bass_pattern_catalogue": [
      { "id": "sustained", "kind": "sustained" },
      { "id": "walking",   "kind": "walking", "density": 2 },
      { "id": "walking_q", "kind": "walking", "density": 4 },
      { "id": "pedal",     "kind": "pedal",   "pedal_degree": 1 },
      { "id": "pedal_dom", "kind": "pedal",   "pedal_degree": 5 }
    ],
    "texture": {
      "default": "pad_bed",
      "rules": [
        { "when": [ {"knob":"subject_energy","op":"ge","lo":0.45,"hi":0.0},
                    {"knob":"fg_bg_contrast","op":"ge","lo":0.25,"hi":0.0} ],
          "pick": "pad_figured" },
        { "when": [ {"knob":"foreground_energy","op":"ge","lo":0.35,"hi":0.0},
                    {"knob":"fg_bg_contrast","op":"ge","lo":0.20,"hi":0.0} ],
          "pick": "pad_bed_counter" },
        { "when": [ {"knob":"arousal","op":"ge","lo":0.70,"hi":0.0},
                    {"knob":"valence","op":"ge","lo":0.55,"hi":0.0} ],
          "pick": "pad_block_comp" },
        { "when": [ {"knob":"arousal","op":"ge","lo":0.60,"hi":0.0} ],
          "pick": "pad_broken_up" },
        { "when": [ {"knob":"valence","op":"ge","lo":0.65,"hi":0.0},
                    {"knob":"colorfulness","op":"ge","lo":0.50,"hi":0.0} ],
          "pick": "pad_arp_waltz" },
        { "when": [ {"knob":"colorfulness","op":"ge","lo":0.40,"hi":0.0} ],
          "pick": "pad_broken_wave" },
        { "when": [ {"knob":"valence","op":"ge","lo":0.60,"hi":0.0},
                    {"knob":"arousal","op":"in_range","lo":0.40,"hi":0.65} ],
          "pick": "pad_oom_pah" },
        { "when": [ {"knob":"arousal","op":"ge","lo":0.75,"hi":0.0},
                    {"knob":"colorfulness","op":"ge","lo":0.55,"hi":0.0} ],
          "pick": "pad_stride" }
      ]
    },
    "prominence_catalogue": [
      { "id": "uniform",        "layers": [] },
      { "id": "subject_melody", "layers": [
          { "role": "Melody",        "weight": 1.0 },
          { "role": "CounterMelody", "weight": 0.6 },
          { "role": "HarmonicFill",  "weight": 0.4 },
          { "role": "Pad",           "weight": 0.3 },
          { "role": "Bass",          "weight": 0.5 } ] }
    ],
    "prominence": {
      "default": "uniform",
      "rules": [
        { "when": [ {"knob":"subject_size",  "op":"in_range","lo":0.05,"hi":0.55},
                    {"knob":"fg_bg_contrast","op":"ge","lo":0.25,"hi":0.0} ],
          "pick": "subject_melody" }
      ]
    }
