          { "at": 0.66, "tone": 2, "register_octaves": 0,  "hold_frac": 0.3 }
        ] },
      { "id": "stride", "voices": 3,
        "onsets": [
          { "at": 0.0,  "tone": 0, "register_octaves": -1, "hold_frac": 0.4 },
